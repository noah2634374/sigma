      "com.example.spawnerutils.SpawnerUtilsAddon"
    ]
  },
  "mixins": [
    "spawnerutils.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.17.0",
    "minecraft": ">=1.21.11",
    "java": ">=21",
    "meteor-client": "*"
