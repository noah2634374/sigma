{
  "schemaVersion": 1,
  "id": "spawnerutils",
  "version": "${version}",

  "name": "SpawnerUtils",
  "description": "Meteor Client Addon: Freecam-Spawner-Breaker, Spawner-ESP, Sus-Chunk-Finder (Amethyst) und Block-Entity-Debug.",
  "authors": [
    "DeinName"
  ],
  "contact": {
    "repo": "https://github.com/DeinName/spawnerutils"
  },

